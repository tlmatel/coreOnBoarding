@{
    ViewData["Title"] = "Público objetivo";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-people fs-2 text-primary me-3"></i>
        <div>
            <h2 class="fw-bold mb-0">Público Objetivo</h2>
            <p class="text-muted mb-0">Fases de liberación, sectores y casos de uso ideales</p>
        </div>
    </div>

    <!-- FASES -->
    <h4 class="fw-bold mb-4">Fases de liberación</h4>

    <div class="row g-4 mb-5">
        <!-- CORE 1 -->
        <div class="col-lg-4">
            <div class="card h-100 border-primary" style="border-width:2px">
                <div class="card-header bg-primary text-white">
                    <h5 class="fw-bold mb-0">CORE 1</h5>
                </div>
                <div class="card-body p-4">
                    <p class="fw-semibold mb-3">Primera liberación orientada a cubrir las funcionalidades de GO!Manage.</p>
                    <h6 class="fw-bold mb-2">Origen del cliente</h6>
                    <ul class="text-muted small mb-3">
                        <li>Nuevo cliente</li>
                        <li>Actual cliente del ERP GO!Manage</li>
                    </ul>
                    <h6 class="fw-bold mb-2">Tipo de empresas</h6>
                    <ul class="text-muted small mb-3">
                        <li>Distribuidores pequeños</li>
                        <li>Distribuidores medianos</li>
                        <li>Empresas multi-sede</li>
                    </ul>
                    <h6 class="fw-bold mb-2">Sectores</h6>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge bg-primary bg-opacity-10 text-primary">Electricidad</span>
                        <span class="badge bg-primary bg-opacity-10 text-primary">Fontanería</span>
                        <span class="badge bg-primary bg-opacity-10 text-primary">Climatización</span>
                        <span class="badge bg-primary bg-opacity-10 text-primary">Material técnico</span>
                    </div>
                    <h6 class="fw-bold mb-2">Características objetivo</h6>
                    <ul class="text-muted small mb-0">
                        <li>Empresas con necesidad de modernización</li>
                        <li>Clientes que buscan reducir infraestructura</li>
                        <li>Empresas que necesitan movilidad y acceso web</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- CORE 2 -->
        <div class="col-lg-4">
            <div class="card h-100 border-success" style="border-width:2px">
                <div class="card-header bg-success text-white">
                    <h5 class="fw-bold mb-0">CORE 2</h5>
                </div>
                <div class="card-body p-4">
                    <p class="fw-semibold mb-3">Ampliación funcional para cubrir GO!Manage y SoftSumind, incluyendo funcionalidades avanzadas para grandes distribuidores.</p>
                    <h6 class="fw-bold mb-2">Origen del cliente</h6>
                    <ul class="text-muted small mb-3">
                        <li>Nuevo cliente</li>
                        <li>Actual cliente de GO!Manage y SoftSumind</li>
                    </ul>
                    <h6 class="fw-bold mb-2">Tipo de empresas</h6>
                    <ul class="text-muted small mb-3">
                        <li>Distribuidores medianos</li>
                        <li>Grandes distribuidores</li>
                        <li>Grupos empresariales</li>
                    </ul>
                    <h6 class="fw-bold mb-2">Características objetivo</h6>
                    <ul class="text-muted small mb-0">
                        <li>Alta escalabilidad</li>
                        <li>Grandes volúmenes de información</li>
                        <li>Operativas complejas</li>
                        <li>Integraciones avanzadas</li>
                        <li>Automatización logística y financiera</li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- CORE 3 -->
        <div class="col-lg-4">
            <div class="card h-100" style="border-width:2px; border-color:#6f42c1">
                <div class="card-header text-white" style="background:#6f42c1">
                    <h5 class="fw-bold mb-0">CORE 3</h5>
                </div>
                <div class="card-body p-4">
                    <p class="fw-semibold mb-3">Ampliación para cobertura completa para empresas instaladoras.</p>
                    <h6 class="fw-bold mb-2">Origen del cliente</h6>
                    <ul class="text-muted small mb-3">
                        <li>Nuevo cliente</li>
                        <li>Actual cliente del ERP GO!Manage</li>
                    </ul>
                    <h6 class="fw-bold mb-2">Tipo de empresas</h6>
                    <ul class="text-muted small mb-3">
                        <li>Instaladores pequeños</li>
                        <li>Instaladores medianos</li>
                        <li>Empresas de servicios técnicos</li>
                    </ul>
                    <h6 class="fw-bold mb-2">Sectores</h6>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="badge bg-opacity-10 text-dark" style="background:rgba(111,66,193,0.1)">Instalaciones eléctricas</span>
                        <span class="badge bg-opacity-10 text-dark" style="background:rgba(111,66,193,0.1)">Climatización</span>
                        <span class="badge bg-opacity-10 text-dark" style="background:rgba(111,66,193,0.1)">Fontanería</span>
                        <span class="badge bg-opacity-10 text-dark" style="background:rgba(111,66,193,0.1)">Mantenimiento técnico</span>
                    </div>
                    <h6 class="fw-bold mb-2">Características objetivo</h6>
                    <ul class="text-muted small mb-0">
                        <li>Movilidad</li>
                        <li>Gestión operativa en campo</li>
                        <li>Acceso remoto</li>
                        <li>Digitalización documental</li>
                        <li>Integración comercial y técnica</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- CASOS DE USO -->
    <h4 class="fw-bold mb-4">Casos de uso ideales</h4>

    <div class="row g-4 mb-4">
        <div class="col-md-6 col-lg-4">
            <div class="card topic-card h-100 p-4">
                <h6 class="fw-bold mb-2"><i class="bi bi-lightning me-2 text-primary"></i>Empresa distribuidora digitalizada</h6>
                <ul class="text-muted small mb-0">
                    <li>Automatizar procesos</li>
                    <li>Integrar eCommerce</li>
                    <li>Mejorar trazabilidad</li>
                    <li>Obtener información en tiempo real</li>
                </ul>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card topic-card h-100 p-4">
                <h6 class="fw-bold mb-2"><i class="bi bi-buildings me-2 text-success"></i>Empresas multisede</h6>
                <ul class="text-muted small mb-0">
                    <li>Gestión centralizada</li>
                    <li>Operación distribuida</li>
                    <li>Acceso global</li>
                    <li>Escalabilidad organizativa</li>
                </ul>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card topic-card h-100 p-4">
                <h6 class="fw-bold mb-2"><i class="bi bi-plug me-2 text-warning"></i>Empresas orientadas a integración</h6>
                <ul class="text-muted small mb-0">
                    <li>Plataformas externas, clientes y proveedores</li>
                    <li>Operadores logísticos</li>
                    <li>Sistemas de BI</li>
                </ul>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card topic-card h-100 p-4">
                <h6 class="fw-bold mb-2"><i class="bi bi-robot me-2 text-info"></i>Empresas orientadas a IA</h6>
                <ul class="text-muted small mb-0">
                    <li>Automatización documental y procesamiento inteligente</li>
                    <li>Asistentes IA y ayuda contextual</li>
                    <li>Búsqueda avanzada y predicción</li>
                </ul>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card topic-card h-100 p-4">
                <h6 class="fw-bold mb-2"><i class="bi bi-graph-up-arrow me-2 text-danger"></i>Empresas en crecimiento</h6>
                <ul class="text-muted small mb-0">
                    <li>Escalar rápidamente</li>
                    <li>Reducir inversiones iniciales</li>
                    <li>Adaptarse al crecimiento</li>
                    <li>Incorporar nuevas sedes y usuarios fácilmente</li>
                </ul>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card topic-card h-100 p-4">
                <h6 class="fw-bold mb-2"><i class="bi bi-cpu me-2" style="color:#6f42c1"></i>ERP preparado para el futuro</h6>
                <ul class="text-muted small mb-0">
                    <li>Automatización avanzada e IA generativa</li>
                    <li>APIs abiertas e integración continua</li>
                    <li>Cloud computing y datos en tiempo real</li>
                </ul>
            </div>
        </div>
    </div>
</div>
