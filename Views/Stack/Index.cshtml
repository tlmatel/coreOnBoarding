            </tr>
            <tr>
                <td><strong>ASP.NET Core</strong></td>
                <td>Framework web para APIs REST (API-First) y MVC.</td>
                <td><span class="badge bg-success">10.0</span></td>
            </tr>
            <tr>
                <td><strong>Entity Framework Core</strong></td>
                <td>ORM para acceso a datos. Migraciones automatizadas.</td>
                <td><span class="badge bg-success">10.0.3</span></td>
            </tr>
            <tr>
                <td><strong>Npgsql</strong></td>
                <td>Driver nativo de PostgreSQL para .NET.</td>
                <td><span class="badge bg-success">10.0.0</span></td>
            </tr>
            <tr>
                <td><strong>PostgreSQL</strong></td>
                <td>Motor de base de datos relacional. BD segregada por tenant.</td>
                <td><span class="badge bg-info">16+</span></td>
            </tr>
        </tbody>
    </table>
</div>

<!-- ── 4. FRONTEND ─────────────────────────────────────────────────────────── -->
