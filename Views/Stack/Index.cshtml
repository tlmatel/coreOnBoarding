@{
    ViewData["Title"] = "Stack Tecnológico";
}

<h1 class="mb-3">Stack <span class="text-primary">Tecnológico</span></h1>
<p class="lead">
    Resumen de todas las tecnologías, herramientas, plataformas y servicios que componen la
    plataforma <strong>CORE</strong> — desde la infraestructura cloud hasta la inteligencia artificial.
</p>

<hr class="my-4">

<!-- ── 1. CLOUD & INFRAESTRUCTURA ─────────────────────────────────────────── -->
<h3 class="mb-3"><i class="bi bi-cloud text-primary"></i> Cloud e infraestructura</h3>
<div class="row g-3 mb-5">
    <div class="col-md-6 col-lg-4">
        <div class="topic-card h-100 p-4">
            <div class="d-flex align-items-center mb-2">
                <span class="badge bg-primary me-2 px-2 py-1">GCP</span>
                <h6 class="fw-bold mb-0">Google Cloud Platform</h6>
            </div>
            <p class="small text-muted mb-0">Proveedor cloud principal. Red global, servicios gestionados y certificaciones de seguridad (ISO 27001, SOC 2, ENS).</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="topic-card h-100 p-4">
            <div class="d-flex align-items-center mb-2">
                <span class="badge bg-primary me-2 px-2 py-1">GKE</span>
                <h6 class="fw-bold mb-0">Google Kubernetes Engine</h6>
            </div>
            <p class="small text-muted mb-0">Clusters gestionados multi-zona con autoescalado, actualizaciones automáticas y alta disponibilidad.</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="topic-card h-100 p-4">
            <div class="d-flex align-items-center mb-2">
                <span class="badge bg-info me-2 px-2 py-1">SQL</span>
                <h6 class="fw-bold mb-0">Cloud SQL</h6>
            </div>
            <p class="small text-muted mb-0">PostgreSQL gestionado con HA y backups automáticos.</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="topic-card h-100 p-4">
            <div class="d-flex align-items-center mb-2">
                <span class="badge bg-success me-2 px-2 py-1">GCS</span>
                <h6 class="fw-bold mb-0">Cloud Storage</h6>
            </div>
            <p class="small text-muted mb-0">Almacenamiento de objetos con versionado y Object Lock para Gestión Documental.</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="topic-card h-100 p-4">
            <div class="d-flex align-items-center mb-2">
                <span class="badge bg-danger me-2 px-2 py-1">Redis</span>
                <h6 class="fw-bold mb-0">Memorystore</h6>
            </div>
            <p class="small text-muted mb-0">Caché Redis gestionado (Standard Tier HA) para datos de sesión y caché de aplicación.</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="topic-card h-100 p-4">
            <div class="d-flex align-items-center mb-2">
                <span class="badge bg-secondary me-2 px-2 py-1">VPC</span>
                <h6 class="fw-bold mb-0">Red y networking</h6>
            </div>
            <p class="small text-muted mb-0">VPC privada, Cloudflare (DNS + CDN), Cloud NAT, Cloud Load Balancer global.</p>
        </div>
    </div>
</div>

<!-- ── 2. CONTENEDORES & ORQUESTACIÓN ─────────────────────────────────────── -->
<h3 class="mb-3"><i class="bi bi-boxes text-success"></i> Contenedores y orquestación</h3>
<div class="row g-3 mb-5">
    <div class="col-md-6 col-lg-3">
        <div class="topic-card h-100 p-4 text-center">
            <i class="bi bi-box fs-2 text-primary"></i>
            <h6 class="fw-bold mt-2">Docker</h6>
            <p class="small text-muted mb-0">Runtime de contenedores. Empaquetado de microservicios.</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="topic-card h-100 p-4 text-center">
            <i class="bi bi-diagram-3 fs-2 text-primary"></i>
            <h6 class="fw-bold mt-2">Kubernetes</h6>
            <p class="small text-muted mb-0">Orquestación, autoescalado, HPA, PDB, namespaces por tenant.</p>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="topic-card h-100 p-4 text-center">
            <i class="bi bi-box-seam fs-2 text-info"></i>
            <h6 class="fw-bold mt-2">Helm</h6>
            <p class="small text-muted mb-0">Gestor de paquetes para K8s. Charts, templating, versionado.</p>
        </div>
    </div>
</div>

<!-- ── 3. BACKEND & API ───────────────────────────────────────────────────── -->
<h3 class="mb-3"><i class="bi bi-code-slash text-danger"></i> Backend y API</h3>
<div class="table-responsive mb-5">
    <table class="table table-bordered align-middle">
        <thead class="table-light">
            <tr>
