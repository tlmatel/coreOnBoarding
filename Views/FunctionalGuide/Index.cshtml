@{
    ViewData["Title"] = "Alcance funcional general";
}

<h1 class="mb-3">Alcance Funcional <span class="text-primary">General</span></h1>
<p class="lead">
    Visión completa de los circuitos funcionales, integraciones y roadmap de versiones de Core OnBoarding.
</p>

<hr class="my-4">

<!-- ═══════════════════════════════════════════════ -->
<!-- ROADMAP DE VERSIONES -->
<!-- ═══════════════════════════════════════════════ -->

<h3 class="mb-3">Roadmap de versiones</h3>

<div class="row g-4 mb-4">
    <!-- CORE 1 -->
    <div class="col-lg-6">
        <div class="topic-card p-4 h-100" style="border-left:4px solid #198754;">
            <div class="d-flex align-items-center mb-3">
                <span class="badge bg-success me-2 px-3 py-2" style="font-size:1rem;">CORE 1</span>
                <span class="text-muted">→ Mar-27</span>
                <span class="badge bg-success bg-opacity-10 text-success ms-auto">6 meses menos</span>
            </div>
            <p class="small text-muted mb-2">Consolida CORE 0 (Dic-26) y CORE 1 (Sep-27) en una entrega adelantada.</p>
            <ul class="small mb-0">
                <li>Multiempresa - Multisede</li>
                <li>Multiubicación</li>
                <li>eDam - GO!Catalog</li>
                <li>SII - Verifactu - Batuz</li>
                <li>Integración CLC, PTL</li>
                <li>Integración CRM/ecommerce vía API</li>
                <li>Circuitos Almacén, Compras, Ventas, Logística y Finanzas</li>
            </ul>
        </div>
    </div>

    <!-- CORE 2 -->
    <div class="col-lg-6">
        <div class="topic-card p-4 h-100" style="border-left:4px solid #0d6efd;">
            <div class="d-flex align-items-center mb-3">
                <span class="badge bg-primary me-2 px-3 py-2" style="font-size:1rem;">CORE 2</span>
                <span class="text-muted">→ Mar-28</span>
                <span class="badge bg-primary bg-opacity-10 text-primary ms-auto">18 meses menos</span>
            </div>
            <p class="small text-muted mb-2">Consolida CORE 2 (Sep-28), CORE 3 (Mar-29) y CORE 4 (Sep-29) en una sola.</p>
            <ul class="small mb-0">
                <li>Integración SGA / IntraDAM / GSGESTIÓN</li>
                <li>Mobilidad de Almacén</li>
                <li>Completar requerimientos DAM y SS de los circuitos</li>
                <li>Almacén, Compras, Ventas, Logística y Finanzas completos</li>
                <li>Gestión de Taller</li>
            </ul>
        </div>
    </div>
</div>

<!-- LÍNEA CRONOLÓGICA -->
<div class="p-4 rounded mt-4" style="background:#f8fafe; border:1px solid #e0eaf5;">
    <h6 class="text-center text-muted mb-4">Línea cronológica — Plan original vs. Plan acelerado</h6>
    <div style="position:relative; padding: 0 20px;">
        <!-- Línea base -->
        <div style="position:absolute; top:50%; left:20px; right:20px; height:3px; background:#ddd; transform:translateY(-50%); z-index:0;"></div>

        <div class="d-flex justify-content-between align-items-center" style="position:relative; z-index:1;">
            <!-- Dic-26 -->
            <div class="text-center" style="flex:0 0 auto;">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center" style="width:40px; height:40px; background:#dc3545; color:#fff; font-size:0.7rem; font-weight:700;">C0</div>
                <div class="small fw-bold mt-1">Dic-26</div>
                <div style="font-size:0.65rem;" class="text-muted">CORE 0<br><span class="text-decoration-line-through">original</span></div>
            </div>

            <!-- Mar-27 (CORE 1 real) -->
            <div class="text-center" style="flex:0 0 auto;">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center" style="width:52px; height:52px; background:#198754; color:#fff; font-size:0.8rem; font-weight:700; box-shadow:0 0 0 4px rgba(25,135,84,0.25);">C1</div>
                <div class="small fw-bold mt-1 text-success">Mar-27</div>
                <div style="font-size:0.65rem;" class="text-success fw-bold">CORE 1 ✓<br>entrega real</div>
            </div>

            <!-- Sep-27 -->
            <div class="text-center" style="flex:0 0 auto;">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center" style="width:40px; height:40px; background:#ccc; color:#666; font-size:0.7rem; font-weight:700;">C1</div>
                <div class="small mt-1 text-muted"><s>Sep-27</s></div>
                <div style="font-size:0.65rem;" class="text-muted">CORE 1<br><span class="text-decoration-line-through">original</span></div>
            </div>

            <!-- Mar-28 (CORE 2 real) -->
            <div class="text-center" style="flex:0 0 auto;">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center" style="width:52px; height:52px; background:#0d6efd; color:#fff; font-size:0.8rem; font-weight:700; box-shadow:0 0 0 4px rgba(13,110,253,0.25);">C2</div>
                <div class="small fw-bold mt-1 text-primary">Mar-28</div>
                <div style="font-size:0.65rem;" class="text-primary fw-bold">CORE 2 ✓<br>entrega real</div>
            </div>

            <!-- Sep-28 -->
            <div class="text-center" style="flex:0 0 auto;">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center" style="width:36px; height:36px; background:#ccc; color:#666; font-size:0.65rem; font-weight:700;">C2</div>
                <div class="small mt-1 text-muted"><s>Sep-28</s></div>
                <div style="font-size:0.65rem;" class="text-muted"><span class="text-decoration-line-through">original</span></div>
            </div>

            <!-- Mar-29 -->
            <div class="text-center" style="flex:0 0 auto;">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center" style="width:36px; height:36px; background:#ccc; color:#666; font-size:0.65rem; font-weight:700;">C3</div>
                <div class="small mt-1 text-muted"><s>Mar-29</s></div>
                <div style="font-size:0.65rem;" class="text-muted"><span class="text-decoration-line-through">original</span></div>
            </div>

            <!-- Sep-29 -->
            <div class="text-center" style="flex:0 0 auto;">
                <div class="rounded-circle d-inline-flex align-items-center justify-content-center" style="width:36px; height:36px; background:#ccc; color:#666; font-size:0.65rem; font-weight:700;">C4</div>
                <div class="small mt-1 text-muted"><s>Sep-29</s></div>
                <div style="font-size:0.65rem;" class="text-muted"><span class="text-decoration-line-through">original</span></div>
            </div>
        </div>
    </div>

    <div class="text-center mt-4">
        <span class="badge bg-success bg-opacity-10 text-success px-3 py-2">CORE 1 → 6 meses de adelanto</span>
        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 ms-2">CORE 2 → 18 meses de adelanto</span>
    </div>
</div>

<hr class="my-4">

