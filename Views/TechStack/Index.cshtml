@{
    ViewData["Title"] = "Core Updates Pipeline";
}

<h2>7. Core Updates Pipeline</h2>
<p class="lead mb-5">Proceso completo de CI/CD con GitOps para el despliegue de microservicios: desde el código fuente hasta producción, pasando por empaquetado Helm y sincronización con ArgoCD.</p>

<!-- LAS 4 FASES -->
<h4 class="fw-bold mb-4">Las 4 fases del pipeline</h4>

<div class="row g-4 mb-5">
    <div class="col-md-6 col-lg-3">
        <div class="card topic-card h-100 p-4">
            <div class="d-flex align-items-center mb-3">
                <span class="section-badge bg-primary me-3" style="font-size: 1.2rem;">1</span>
                <h6 class="fw-bold mb-0">Desarrollo</h6>
            </div>
            <p class="text-muted mb-3">Los desarrolladores hacen push al repositorio de microservicios. Tags y commits disparan distintos flujos de CI.</p>
            <a asp-action="Development" class="btn btn-outline-primary btn-sm mt-auto align-self-start">Ver detalle</a>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card topic-card h-100 p-4">
            <div class="d-flex align-items-center mb-3">
                <span class="section-badge bg-success me-3" style="font-size: 1.2rem;">2</span>
                <h6 class="fw-bold mb-0">Empaquetado</h6>
            </div>
            <p class="text-muted mb-3">GitHub Actions empaqueta Helm charts y los publica como paquetes OCI en registries dedicados.</p>
            <a asp-action="Packaging" class="btn btn-outline-success btn-sm mt-auto align-self-start">Ver detalle</a>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card topic-card h-100 p-4">
            <div class="d-flex align-items-center mb-3">
                <span class="section-badge me-3" style="background-color: #6f42c1; font-size: 1.2rem;">3</span>
                <h6 class="fw-bold mb-0">Despliegue</h6>
            </div>
            <p class="text-muted mb-3">ArgoCD detecta cambios en los charts y en el deployment repo, y sincroniza el estado con el cluster CORE.</p>
            <a asp-action="Deployment" class="btn btn-outline-secondary btn-sm mt-auto align-self-start" style="border-color: #6f42c1; color: #6f42c1;">Ver detalle</a>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card topic-card h-100 p-4">
            <div class="d-flex align-items-center mb-3">
                <span class="section-badge bg-warning text-dark me-3" style="font-size: 1.2rem;">4</span>
                <h6 class="fw-bold mb-0">Operaciones</h6>
            </div>
            <p class="text-muted mb-3">El Control Panel permite gestionar versiones, actualizaciones de clientes, DNS y migraciones de base de datos.</p>
            <a asp-action="Operations" class="btn btn-outline-warning btn-sm mt-auto align-self-start">Ver detalle</a>
        </div>
    </div>
</div>

<!-- TECNOLOGÍAS -->
<h4 class="fw-bold mb-4">Tecnologías del pipeline</h4>

<div class="row g-3 mb-5">
    <div class="col-md-4">
        <div class="d-flex align-items-center p-3 bg-light rounded">
            <i class="bi bi-github me-3 fs-4"></i>
            <div>
                <strong>GitHub</strong>
                <div class="text-muted small">Repositorios & Actions</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="d-flex align-items-center p-3 bg-light rounded">
            <i class="bi bi-box-seam me-3 fs-4 text-primary"></i>
            <div>
                <strong>Helm</strong>
                <div class="text-muted small">Empaquetado de charts</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="d-flex align-items-center p-3 bg-light rounded">
            <i class="bi bi-archive me-3 fs-4 text-success"></i>
            <div>
                <strong>OCI Registry</strong>
                <div class="text-muted small">Almacén de artefactos</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="d-flex align-items-center p-3 bg-light rounded">
            <i class="bi bi-arrow-repeat me-3 fs-4" style="color: #6f42c1;"></i>
            <div>
                <strong>ArgoCD</strong>
                <div class="text-muted small">GitOps & despliegue</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="d-flex align-items-center p-3 bg-light rounded">
            <i class="bi bi-database me-3 fs-4 text-info"></i>
            <div>
                <strong>PostgreSQL</strong>
                <div class="text-muted small">Base de datos</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="d-flex align-items-center p-3 bg-light rounded">
            <i class="bi bi-sliders me-3 fs-4 text-warning"></i>
            <div>
                <strong>Control Panel</strong>
                <div class="text-muted small">Gestión operativa</div>
            </div>
        </div>
    </div>
</div>

<!-- DIAGRAMA DE FLUJO -->
<h4 class="fw-bold mb-4">Diagrama de flujo completo</h4>

<style>
    .pipeline-box {
        background: #fff;
