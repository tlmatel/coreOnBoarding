        padding: 0.75rem 1.25rem;
        text-align: center;
        min-width: 120px;
    }
    .pipeline-box.highlight-blue { border: 2px solid #0d6efd; }
    .pipeline-box.highlight-green { border: 2px solid #198754; }
    .pipeline-box.highlight-purple { border: 2px solid #6f42c1; }
    .pipeline-box.highlight-orange { border: 2px solid #fd7e14; }
    .pipeline-box .box-icon { font-size: 1.4rem; display: block; margin-bottom: 0.25rem; }
    .pipeline-box .box-label { font-size: 0.85rem; font-weight: 600; }
    .pipeline-box .box-sub { font-size: 0.7rem; color: #6c757d; }
    .pipeline-arrow { color: #adb5bd; font-size: 1.2rem; }
    .pipeline-connector { font-size: 0.75rem; color: #6c757d; white-space: nowrap; }
    .pipeline-lane {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding: 1.25rem 0;
    }
    .pipeline-lane-header {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6c757d;
        padding: 0.5rem 1rem;
        border-radius: 2rem;
        display: inline-block;
        margin-bottom: 0.5rem;
    }
</style>

