            <thead class="table-light">
                <tr>
                    <th style="width:40%">Ámbito / Opción</th>
                    <th class="text-center" style="width:15%">Lectura</th>
                    <th class="text-center" style="width:15%">Escritura</th>
                    <th>Observaciones</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><i class="bi bi-boxes text-secondary me-1"></i> Consulta de stock</td>
                    <td class="text-center perm-allow"><i class="bi bi-check-circle-fill"></i></td>
                    <td class="text-center perm-none"><i class="bi bi-dash"></i></td>
                    <td class="small">Solo visualización de existencias</td>
                </tr>
                <tr>
                    <td><i class="bi bi-arrow-left-right text-secondary me-1"></i> Movimientos de almacén</td>
                    <td class="text-center perm-allow"><i class="bi bi-check-circle-fill"></i></td>
                    <td class="text-center perm-allow"><i class="bi bi-check-circle-fill"></i></td>
                    <td class="small">Puede registrar entradas, salidas y ajustes</td>
                </tr>
                <tr>
                    <td><i class="bi bi-arrow-down-circle text-secondary me-1"></i> Albaranes de compra</td>
                    <td class="text-center perm-allow"><i class="bi bi-check-circle-fill"></i></td>
                    <td class="text-center perm-allow"><i class="bi bi-check-circle-fill"></i></td>
                    <td class="small">Puede recepcionar mercancía</td>
                </tr>
                <tr>
                    <td><i class="bi bi-shuffle text-secondary me-1"></i> Traspasos entre sedes</td>
                    <td class="text-center perm-allow"><i class="bi bi-check-circle-fill"></i></td>
                    <td class="text-center perm-allow"><i class="bi bi-check-circle-fill"></i></td>
                    <td class="small">Gestión de traslados de stock</td>
                </tr>
                <tr>
                    <td><i class="bi bi-receipt text-secondary me-1"></i> Facturación</td>
                    <td class="text-center perm-deny"><i class="bi bi-x-circle-fill"></i></td>
                    <td class="text-center perm-deny"><i class="bi bi-x-circle-fill"></i></td>
                    <td class="small">Sin acceso — no es su área</td>
                </tr>
                <tr>
                    <td><i class="bi bi-cash-stack text-secondary me-1"></i> Contabilidad</td>
                    <td class="text-center perm-deny"><i class="bi bi-x-circle-fill"></i></td>
                    <td class="text-center perm-deny"><i class="bi bi-x-circle-fill"></i></td>
                    <td class="small">Sin acceso — no es su área</td>
                </tr>
                <tr>
                    <td><i class="bi bi-gear text-secondary me-1"></i> Configuración del sistema</td>
