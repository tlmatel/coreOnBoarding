    .perm-allow { color: #198754; font-weight: 600; }
    .perm-deny  { color: #dc3545; font-weight: 600; }
    .perm-none  { color: #aaa; }
</style>

<div class="p-4 rounded mb-3" style="background:#f8f9fa; border:1px solid #e0e0e0;">
    <div class="d-flex align-items-center gap-2 mb-3">
        <span class="badge rounded-pill" style="background:#00838f; font-size:0.9rem; padding: 0.4rem 0.9rem;">
            <i class="bi bi-box-seam me-1"></i> Rol: Almacén
