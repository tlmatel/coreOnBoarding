@{
    ViewData["Title"] = "Infraestructura GCP";
}

<h1 class="mb-3">Infraestructura — <span class="text-primary">Google Cloud Platform</span></h1>
<p class="lead">
    La infraestructura de Core OnBoarding aprovecha la red global de Google para ofrecer
    baja latencia, alta disponibilidad y aislamiento de recursos entre tenants.
</p>

<hr class="my-4">

<h3 class="mb-3">Topología de red</h3>
<div class="row g-4">
    <div class="col-lg-8">
        <div class="p-4 rounded" style="background:#f8fafe; border:1px solid #e0eaf5;">
            <div class="text-center mb-3">
                <div style="display:inline-block; padding:12px 24px; background:#4285f4; color:#fff; border-radius:8px; font-weight:600;">
                    Internet / Usuarios
                </div>
                <div class="my-2"><i class="bi bi-arrow-down fs-4 text-primary"></i></div>
                <div style="display:inline-block; padding:12px 24px; background:#34a853; color:#fff; border-radius:8px; font-weight:600;">
                    Cloud Load Balancer (Global)
                </div>
                <div class="my-2"><i class="bi bi-arrow-down fs-4 text-success"></i></div>
                <div style="display:inline-block; padding:12px 24px; background:#fbbc04; color:#333; border-radius:8px; font-weight:600;">
                    Cloud Armor (WAF + DDoS)
                </div>
                <div class="my-2"><i class="bi bi-arrow-down fs-4 text-warning"></i></div>
                <div style="display:inline-block; padding:12px 24px; background:#ea4335; color:#fff; border-radius:8px; font-weight:600;">
                    VPC Privada — GKE Cluster
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="topic-card h-100">
            <h5>Componentes principales</h5>
            <ul class="mb-0">
                <li><strong>VPC</strong> — Red privada aislada</li>
                <li><strong>Subnets</strong> — Segmentación por entorno</li>
                <li><strong>Cloud NAT</strong> — Salida controlada</li>
                <li><strong>Cloudflare</strong> — DNS, CDN y protección DDoS</li>
                <li><strong>Firewall Rules</strong> — Zero-trust</li>
                <li><strong>Private Google Access</strong> — APIs sin Internet</li>
            </ul>
        </div>
    </div>
</div>

<hr class="my-4">

<h3 class="mb-3">Servicios GCP utilizados</h3>
<div class="row g-3">
    <div class="col-md-6 col-lg-4">
        <div class="topic-card h-100">
            <h6><i class="bi bi-hdd-stack text-primary"></i> Compute</h6>
            <ul class="small mb-0">
                <li>GKE (Kubernetes Engine)</li>
                <li>Cloud Run (jobs auxiliares)</li>
                <li>Compute Engine (bastion hosts)</li>
            </ul>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="topic-card h-100">
            <h6><i class="bi bi-database text-primary"></i> Datos</h6>
            <ul class="small mb-0">
                <li>Cloud SQL (PostgreSQL gestionado)</li>
                <li>Cloud Storage (objetos/blobs)</li>
                <li>Memorystore (Redis cache)</li>
            </ul>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="topic-card h-100">
            <h6><i class="bi bi-shield-lock text-primary"></i> Seguridad</h6>
            <ul class="small mb-0">
                <li>Cloud Armor (WAF)</li>
                <li>Secret Manager</li>
                <li>Cloud KMS (cifrado)</li>
            </ul>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="topic-card h-100">
            <h6><i class="bi bi-diagram-2 text-primary"></i> Networking</h6>
            <ul class="small mb-0">
                <li>Cloud Load Balancing</li>
                <li>Cloud CDN</li>
                <li>Cloud Interconnect</li>
            </ul>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="topic-card h-100">
            <h6><i class="bi bi-eye text-primary"></i> Observabilidad</h6>
            <ul class="small mb-0">
                <li>Prometheus + Grafana</li>
                <li>Loki + Promtail</li>
                <li>Tempo + OpenTelemetry</li>
            </ul>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="topic-card h-100">
            <h6><i class="bi bi-gear text-primary"></i> DevOps</h6>
            <ul class="small mb-0">
                <li>Artifact Registry (imágenes)</li>
                <li>Cloud Build (CI opcional)</li>
                <li>Cloud Deploy (CD opcional)</li>
            </ul>
        </div>
    </div>
</div>

<hr class="my-4">

<h3 class="mb-3">Entornos desplegados</h3>
<table class="table table-bordered">
    <thead class="table-light">
        <tr><th>Entorno</th><th>Proyecto GCP</th><th>Región</th><th>Propósito</th></tr>
    </thead>
    <tbody>
        <tr><td><span class="badge bg-info">DEV</span></td><td>core-onboarding-dev</td><td>europe-southwest1</td><td>Desarrollo y pruebas internas</td></tr>
        <tr><td><span class="badge bg-warning text-dark">STAGING</span></td><td>core-onboarding-stg</td><td>europe-southwest1</td><td>Pre-producción, validación cliente</td></tr>
        <tr><td><span class="badge bg-success">PROD</span></td><td>core-onboarding-prod</td><td>europe-southwest1</td><td>Producción multi-tenant</td></tr>
    </tbody>
</table>

<hr class="my-5">

<h3 class="mb-3"><i class="bi bi-book text-secondary"></i> Glosario</h3>
<div class="table-responsive">
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr><th style="width:20%">Término</th><th>Definición</th></tr>
        </thead>
        <tbody>
            <tr><td><strong>VPC</strong></td><td>Virtual Private Cloud — red privada virtual aislada dentro de GCP donde se despliegan los recursos.</td></tr>
            <tr><td><strong>Subnet</strong></td><td>Subred dentro de una VPC que segmenta el tráfico por entorno o función.</td></tr>
            <tr><td><strong>Cloud NAT</strong></td><td>Servicio de traducción de direcciones de red que permite a recursos sin IP pública acceder a Internet de forma controlada.</td></tr>
            <tr><td><strong>WAF</strong></td><td>Web Application Firewall — filtro que protege aplicaciones web contra ataques como inyección SQL o XSS.</td></tr>
            <tr><td><strong>DDoS</strong></td><td>Distributed Denial of Service — ataque que intenta saturar un servicio con tráfico masivo desde múltiples orígenes.</td></tr>
            <tr><td><strong>Load Balancer</strong></td><td>Balanceador de carga — distribuye el tráfico entrante entre varios servidores para mejorar rendimiento y disponibilidad.</td></tr>
            <tr><td><strong>Bastion Host</strong></td><td>Servidor intermedio seguro que actúa como punto de entrada para acceder a recursos en una red privada.</td></tr>
            <tr><td><strong>CDN</strong></td><td>Content Delivery Network — red de servidores distribuidos que cachean contenido cerca del usuario para reducir latencia.</td></tr>
            <tr><td><strong>Cloud SQL</strong></td><td>Servicio gestionado de GCP para bases de datos relacionales (PostgreSQL, MySQL) con backups y HA automáticos.</td></tr>
            <tr><td><strong>Memorystore</strong></td><td>Servicio gestionado de Redis/Memcached en GCP, usado como caché en memoria para acelerar consultas.</td></tr>
            <tr><td><strong>Private Google Access</strong></td><td>Permite a recursos sin IP pública acceder a las APIs de Google sin salir a Internet.</td></tr>
            <tr><td><strong>Sidecar</strong></td><td>Contenedor auxiliar que se ejecuta junto al contenedor principal dentro del mismo pod, proporcionando funciones complementarias.</td></tr>
        </tbody>
    </table>
</div>
