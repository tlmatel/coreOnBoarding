@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <i class="bi bi-person-circle fs-2 text-primary me-3"></i>
        <div>
            <h2 class="fw-bold mb-0">Mi Perfil</h2>
            <p class="text-muted mb-0">Información de tu cuenta Auth0</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm text-center p-4">
                @{
                    var picture = User.Claims.FirstOrDefault(c => c.Type == "picture")?.Value;
                    var name = User.Identity?.Name ?? "Usuario";
                }
                @if (!string.IsNullOrEmpty(picture))
                {
                    <img src="@picture" alt="Avatar" class="rounded-circle mb-3" width="96" height="96" />
                }
                else
                {
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width:96px;height:96px;font-size:2.5rem;font-weight:700;">
                        @name[0]
                    </div>
                }
                <h4 class="fw-bold mb-1">@name</h4>
                <p class="text-muted">@(User.Claims.FirstOrDefault(c => c.Type == "email" || c.Type == System.Security.Claims.ClaimTypes.Email)?.Value ?? "—")</p>
                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm mt-2">
                    <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
                </a>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h5 class="fw-bold mb-0"><i class="bi bi-key me-2"></i>Claims del token</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:35%">Claim</th>
                                <th>Valor</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var claim in User.Claims)
                            {
                                <tr>
                                    <td><code>@claim.Type</code></td>
                                    <td class="text-break">@claim.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
