@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = null;

    var reason = User.FindFirst("hubrd_reason")?.Value ?? "";
    var message = reason switch
    {
        "no_access" => "Tu cuenta no tiene permisos para acceder a este portal. Contacta con tu administrador.",
        "user_not_found" => "Tu email no está registrado en el sistema. Contacta con tu administrador.",
        "api_error" => "Se produjo un error temporal al verificar tus permisos. Inténtalo de nuevo en unos minutos.",
        _ => "No tienes permisos para acceder a este recurso."
    };
    var isTemporaryError = reason == "api_error";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acceso Denegado - Core OnBoarding</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #f0f4ff 0%, #e8eeff 50%, #f5f0ff 100%);
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }
        .access-card {
            max-width: 460px;
            width: 100%;
            border-radius: 20px;
            overflow: hidden;
            border: none;
        }
        .access-header {
            background: linear-gradient(135deg, #dc3545 0%, #ef4444 100%);
            color: white;
            padding: 3rem 2rem 2.5rem;
            text-align: center;
        }
        .access-header.warning {
            background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
        }
        .access-logo {
            width: 72px;
            height: 72px;
            background: rgba(255,255,255,0.2);
            border-radius: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 1.2rem;
            backdrop-filter: blur(10px);
        }
        .access-header h2 {
            font-weight: 700;
            margin-bottom: 0.3rem;
        }
        .access-header p {
            opacity: 0.85;
            font-size: 0.95rem;
            margin-bottom: 0;
        }
        .card-body {
            padding: 2rem;
        }
        .card-body h5 {
            font-weight: 600;
            margin-bottom: 0.4rem;
        }
        .card-body .desc {
            color: #6c757d;
            margin-bottom: 1.5rem;
            font-size: 0.95rem;
        }
        .btn-action {
            display: block;
            width: 100%;
            background: linear-gradient(135deg, #dc3545, #ef4444);
            border: none;
            color: #fff;
            font-weight: 600;
            padding: 0.85rem;
            font-size: 1.05rem;
            border-radius: 12px;
            transition: all 0.2s;
            text-decoration: none;
            text-align: center;
        }
        .btn-action.warning {
            background: linear-gradient(135deg, #0d6efd, #4f9cff);
        }
        .btn-action:hover {
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.15);
        }
        .btn-secondary-link {
            display: block;
            width: 100%;
            text-align: center;
            color: #6c757d;
            text-decoration: none;
            font-size: 0.95rem;
            padding: 0.6rem;
            border-radius: 12px;
            transition: all 0.15s;
        }
        .btn-secondary-link:hover {
            background: #f8f9fa;
            color: #495057;
        }
        .footer-note {
            text-align: center;
            margin-top: 1rem;
            font-size: 0.85rem;
            color: #94a3b8;
        }
    </style>
</head>
<body>
    <div class="access-card shadow-lg card">
        <div class="access-header @(isTemporaryError ? "warning" : "")">
            <div class="access-logo">
                <i class="bi @(isTemporaryError ? "bi-exclamation-triangle" : "bi-shield-x")"></i>
            </div>
            <h2>Acceso denegado</h2>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <p>@(User.Claims.FirstOrDefault(c => c.Type == "email"
                    || c.Type == System.Security.Claims.ClaimTypes.Email)?.Value
                    ?? User.Identity.Name)</p>
            }
        </div>
        <div class="card-body">
            <h5>@(isTemporaryError ? "Error temporal" : "Sin acceso")</h5>
            <p class="desc">@message</p>

            @if (isTemporaryError)
            {
                <a asp-controller="Home" asp-action="Index" class="btn-action warning">
                    <i class="bi bi-arrow-clockwise me-2"></i>Reintentar
                </a>
                <a asp-controller="Account" asp-action="Logout" class="btn-secondary-link mt-2">
                    <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión e intentar con otra cuenta
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Logout" class="btn-action">
                    <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                </a>
            }

            <div class="footer-note">
                <i class="bi bi-shield-check me-1"></i>
                Conexión segura mediante SSO
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
